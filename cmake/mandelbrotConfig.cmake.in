@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set(MANDELBROT_HAS_OMP @MANDELBROT_HAS_OMP@)
set(MANDELBROT_HAS_GPU @MANDELBROT_HAS_GPU@)

if(MANDELBROT_HAS_OMP AND NOT TARGET OpenMP::OpenMP_CXX)
    find_dependency(OpenMP REQUIRED COMPONENTS CXX)
endif()

if(MANDELBROT_HAS_GPU AND NOT TARGET CUDA::cudart)
    find_dependency(CUDAToolkit REQUIRED)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/mandelbrotTargets.cmake")

check_required_components(mandelbrot)
